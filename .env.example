# Your ntfy topic (pick something unique/secret, e.g. "jaypreak-insta-alerts-x7k2")
NTFY_TOPIC=your-secret-topic-name

# Comma-separated Instagram usernames to track
INSTAGRAM_USERNAMES=username1,username2

# Upstash Redis (auto-set when you add Redis from Vercel Marketplace)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
